{
  "name": "dojo-planner-kiosk",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "dev": "run-p db-server dev:next",
    "dev:next": "next dev",
    "db-server": "pglite-server --db=../dojo-planner/local.db",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check:types": "tsc --noEmit",
    "check:deps": "knip",
    "prepare": "lefthook install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@dojo-planner/iqpro-client": "github:rccn-llc/iqpro-client",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@types/pg": "^8.16.0",
    "@upstash/redis": "^1.36.1",
    "@xstate/react": "^6.0.0",
    "drizzle-orm": "^0.45.1",
    "next": "16.1.6",
    "pg": "^8.17.2",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.4",
    "xstate": "^5.26.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "package-lock.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.15.10",
    "@chromatic-com/storybook": "^5.1.1",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@commitlint/types": "^20.4.0",
    "@electric-sql/pglite": "^0.3.15",
    "@electric-sql/pglite-socket": "^0.0.21",
    "@eslint-react/eslint-plugin": "^1.53.1",
    "@next/eslint-plugin-next": "^15.5.12",
    "@playwright/test": "^1.58.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.4",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-onboarding": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/nextjs-vite": "^10.3.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-plugin-format": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "knip": "^5.83.1",
    "lefthook": "^2.1.0",
    "npm-run-all": "^4.1.5",
    "pglite-server": "^0.1.0",
    "playwright": "^1.59.1",
    "postcss": "^8",
    "semantic-release": "^25.0.3",
    "storybook": "^10.3.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^8.0.3",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.1.2"
  }
}
